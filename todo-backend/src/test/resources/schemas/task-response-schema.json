{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CategoryResponse",
  "type": "object",

  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "name": {
      "type": "string"
    },
    "dueDate": {
      "type": "string",
      "format": "date"
    },
    "isArchived": {
      "type": "boolean"
    },
    "categoryName": {
      "type": "string"
    },
    "categoryId": {
      "type": "integer",
      "format": "int64"
    }
  },
  "required": [
    "id",
    "name",
    "dueDate",
    "isArchived",
    "categoryName",
    "categoryId"
  ],
  "additionalProperties": false
}
